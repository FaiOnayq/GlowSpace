<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login</title>
  <link rel="stylesheet" href="/css/login.css">
  <link
    href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap"
    rel="stylesheet">

</head>

<body>
  <%- include('../partials/header') %>
    <%- include('../partials/navbar') %>
      <div class="container">

        <header>
          <div class="logo">
            <img src="/images/GlowSpace.png" alt="GlowSpace Logo">
          </div>
        </header>

        <main>
          <div class="formcontainer">
            <h3>Admin Login</h3>
              <form class="loginform" action="/admin/login" method="post">
                <div class="container1">
                  <%- include('../partials/flashMessages') %>
                  <label for="email">Email</label>
                  <input type="email" name="email" id="email" required>
                  <label for="password">Password</label>
                  <input type="password" name="password" id="password" required>
                  <a class="nav-link" href="/admin/signup">Don't have an account?</a>
                </div>
                <div>
                  <button type="submit" class="back-link" > Login</button>
                </div>
              </form>
          </div>
        </main>
      </div>
      <%- include('../partials/footer') %>
</body>

</html>
