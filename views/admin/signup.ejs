<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign Up</title>
    <link rel="icon" type="image/x-icon" href="./images/tab.png">
    <link rel="stylesheet" href="/css/login.css">
    <link
        href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">

</head>
<body>
<%- include('../partials/header') %>
<%- include('../partials/navbar') %>
<div class="container">

  <header>
    <div class="logo">
      <img src="/images/GlowSpace.png" alt="GlowSpace Logo">
    </div>
  </header>
  <main>
    <div class="formcontainer">
      <h3>Admin Sign Up</h3>
      <%- include('../partials/flashMessages') %>
            <form  class="loginform" action="/admin/signup" method="post">
                <div class="container1">
                    <label for="email">Email</label>
                    <input type="text" name="email" id="email" required>
                    <label for="password">Password</label>
                    <input type="password" name="password" id="password"  required>

                    <label for="confirm_password">Confirm Password</label>
                    <input type="password" name="confirm_password" id="confirm_password" required>

                    <label for="salonName">Salon Name:</label>
                    <input type="text" id="salonName" name="salonName" required>
                    <label for="salonLocation">Salon Location:</label>
                    <input type="text" id="salonLocation" name="salonLocation" required>
                    <label for="salonPhone">Salon Phone:</label>
                    <input type="text" id="salonPhone" name="salonPhone" required>
                    <div class="submit">
                      <button type="submit" class="back-link" > Sign Up</button>
                  </div>
                </div>

            </form>

        </div>
    </main>
</div>
</body>

<%- include('../partials/footer') -%>
</html>
